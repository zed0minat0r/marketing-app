# =============================================
# TextMarketer Environment Variables
# Copy to .env.local for local development
# Set all in Vercel dashboard for production
# =============================================

# ----------------------------
# Twilio (SMS Gateway)
# ----------------------------
# Found at: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX   # Your Twilio number (E.164 format)

# ----------------------------
# Claude API (Anthropic)
# ----------------------------
# Found at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------
# Supabase (Database)
# ----------------------------
# Found at: https://supabase.com/dashboard -> Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Service role key (not anon key)
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx           # Anon key (for client-side if needed)

# ----------------------------
# Meta (Facebook + Instagram OAuth)
# ----------------------------
# Found at: https://developers.facebook.com -> Your App -> Settings -> Basic
META_APP_ID=xxxxxxxxxxxx
META_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------
# X / Twitter (OAuth 2.0 PKCE)
# ----------------------------
# Found at: https://developer.twitter.com/en/portal -> Your App -> Keys and Tokens
TWITTER_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
TWITTER_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------
# LinkedIn (Marketing API / UGC Posts)
# ----------------------------
# Found at: https://www.linkedin.com/developers/apps -> Your App -> Auth
# Required scopes: w_member_social, r_liteprofile, r_emailaddress
# Tokens expire after 60 days; users must reconnect to renew
LINKEDIN_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
LINKEDIN_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------
# Pinterest (API v5)
# ----------------------------
# Found at: https://developers.pinterest.com/apps/ -> Your App -> Authentication
# Required scopes: pins:read, pins:write, boards:read, user_accounts:read
# Tokens are long-lived (no expiry) — no refresh needed
PINTEREST_CLIENT_ID=xxxxxxxxxxxx
PINTEREST_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------
# Google Business Profile (Business Profile API)
# ----------------------------
# Found at: https://console.cloud.google.com -> APIs & Services -> Credentials
# Enable: Business Profile API, My Business Business Information API
# Required scopes: business.manage, userinfo.profile, userinfo.email
# Access tokens expire in 1 hour; refresh tokens are long-lived
# Set redirect URI: {APP_URL}/api/oauth/google/callback
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------
# Stripe (Billing)
# ----------------------------
# Found at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_secret_key_here        # format: sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here  # format: whsec_...

# Stripe Price IDs (create products/prices in Stripe dashboard)
# Starter: $49/mo, Growth: $99/mo, Pro: $199/mo
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_GROWTH=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxx

# ----------------------------
# Upstash (QStash + Redis)
# ----------------------------
# Found at: https://console.upstash.com
# QStash — for scheduled job delivery
QSTASH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QSTASH_CURRENT_SIGNING_KEY=sig_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QSTASH_NEXT_SIGNING_KEY=sig_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redis — for rate limiting (distributed across Vercel functions)
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------
# Cloudflare R2 (Photo storage for MMS intake)
# ----------------------------
# Create a bucket at: https://dash.cloudflare.com -> R2
# Then make an API token with R2 read/write scope and copy the keys below.
# Endpoint URL is the S3-compatible endpoint for your account.
# Public base URL is your custom domain or r2.dev public bucket URL.
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=sidekick-photos
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://photos.sidekik.com   # custom domain on the bucket

# ----------------------------
# Replicate (Photo enhancement — auto upscale + sharpen + face enhance)
# ----------------------------
# Token at: https://replicate.com/account/api-tokens
# Default model is Real-ESRGAN. Override with REPLICATE_ENHANCE_MODEL if you
# want to pin a different version hash.
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# REPLICATE_ENHANCE_MODEL=                                # optional model-version-hash override

# ----------------------------
# Admin Dashboard Auth
# ----------------------------
# SHA-256 hash of the admin password. The admin UI checks the password client-
# side against the hash baked into admin.html, but server-backed admin
# endpoints (under /api/admin/*) ALSO validate it independently. Set this in
# Vercel so admin endpoints actually return data in prod.
# Generate with:
#   echo -n "your-admin-password" | shasum -a 256 | cut -d' ' -f1
ADMIN_PASSWORD_HASH=d5f8bc0ae15d0bb9d626cca99374faff8bbb9bc68cde0f75b2331c34f119c901

# ----------------------------
# Application
# ----------------------------
APP_URL=https://textmarketer.com     # Your production URL (no trailing slash)

# Encryption key for sensitive data at rest (32 random bytes, hex-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------
# Email (Transactional)
# ----------------------------
# Set EMAIL_PROVIDER to either "sendgrid" or "resend" — only one is needed.

# Provider selection
EMAIL_PROVIDER=resend   # "sendgrid" or "resend"

# From address (used in the From: header)
EMAIL_FROM=Sidekick <hello@getsidekick.co>

# SendGrid — https://app.sendgrid.com/settings/api_keys
# Required scope: Mail Send
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend — https://resend.com/api-keys
# Required scope: Full access (or Send Email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
