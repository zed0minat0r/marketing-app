{
  "version": 2,
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "functions": {
    "api/sms/inbound.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/jobs/[action].js": {
      "memory": 512,
      "maxDuration": 300
    },
    "api/stripe/webhook.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/jobs/collect-analytics",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/jobs/weekly-summary",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/jobs/refresh-tokens",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/jobs/reset-generations",
      "schedule": "5 0 1 * *"
    },
    {
      "path": "/api/jobs/cleanup-conversations",
      "schedule": "0 5 * * 0"
    }
  ],
  "rewrites": [
    { "source": "/connected", "destination": "/connected.html" },
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "headers": [
    {
      "source": "/admin",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/admin.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    }
  ]
}
