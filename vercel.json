{
  "version": 2,
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "functions": {
    "api/sms/inbound.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/jobs/[action].js": {
      "memory": 512,
      "maxDuration": 300
    },
    "api/stripe/webhook.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/connected", "destination": "/connected.html" },
    { "source": "/admin", "destination": "/admin.html" }
  ]
}
